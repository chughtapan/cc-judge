{
  "name": "@moltzap/cc-judge",
  "version": "0.0.3",
  "description": "TypeScript CLI + SDK for planned Claude Code harness runs, LLM bundle judging, and summary.md + results.jsonl reports with Braintrust + Promptfoo telemetry.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "cc-judge": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/app",
    "dist/core",
    "dist/emit",
    "dist/judge",
    "dist/plans",
    "dist/runner",
    "dist/*.d.ts",
    "dist/*.d.ts.map",
    "dist/*.js",
    "dist/*.js.map",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "pnpm clean && tsc && chmod +x dist/bin.js",
    "typecheck": "tsc --noEmit -p tsconfig.test.json",
    "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts'",
    "test": "vitest run",
    "test:watch": "vitest",
    "mutation": "stryker run",
    "prepublishOnly": "pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "keywords": [
    "claude",
    "claude-code",
    "evals",
    "agent",
    "llm-judge",
    "typescript"
  ],
  "license": "MIT",
  "author": "Tapan Chugh",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chughtapan/cc-judge.git"
  },
  "homepage": "https://github.com/chughtapan/cc-judge#readme",
  "bugs": {
    "url": "https://github.com/chughtapan/cc-judge/issues"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.1.45",
    "@effect/cli": "0.75.1",
    "@effect/platform": "0.96.1",
    "@effect/platform-node": "0.106.0",
    "@sinclair/typebox": "0.33.22",
    "braintrust": "0.0.180",
    "dockerode": "5.0.0",
    "effect": "3.21.0",
    "glob": "11.0.0",
    "proper-lockfile": "4.1.2",
    "tar-fs": "3.1.2",
    "yaml": "2.6.1"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/dockerode": "4.0.1",
    "@types/node": "22.10.5",
    "@types/proper-lockfile": "4.1.4",
    "@types/tar-fs": "2.0.4",
    "@typescript-eslint/eslint-plugin": "8.19.0",
    "@typescript-eslint/parser": "8.19.0",
    "eslint": "9.17.0",
    "eslint-plugin-agent-code-guard": "0.0.5",
    "fast-check": "4.7.0",
    "typescript": "5.6.3",
    "vitest": "2.1.9"
  }
}
